# dependencies
node_modules
.pnp.*
.pnp.loader.mjs

# yarn berry (committed: yarn.lock, .yarnrc.yml, .yarn/patches, .yarn/plugins, .yarn/releases, .yarn/sdks, .yarn/versions)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
**/.yarn/install-state.gz
**/.yarn/cache
**/.yarn/unplugged

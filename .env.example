# ── Required ──────────────────────────────────────────────
# Session cookie encryption key (>= 32 chars). Rotating this
# invalidates every existing session cookie — a hard sign-out.
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-with-openssl-rand-hex-32

# Team shared password. Stored in plaintext, compared in
# constant time. Rotate quarterly (or on any suspected leak).
SHARED_PASSWORD=change-me

# Root directory exposed to the read-only file viewer (§12).
# Everything outside this path is inaccessible to the API and UI.
# In Docker this is typically /workspace, bind-mounted :ro from the host.
# Locally (no container), set to an absolute path on disk, e.g.
#   /Users/alice/projects
WORKSPACE_ROOT=/workspace

# ── Optional ──────────────────────────────────────────────
# Comma-separated origin whitelist for WebSocket upgrades.
# Leave empty during local/testing; set to the exact origin(s)
# once deployed behind a reverse proxy (e.g. "http://10.10.1.50").
ALLOWED_ORIGINS=

# Next.js will read NEXT_PUBLIC_* at build time and expose them
# to the browser. Set when the WS gateway is reached through
# nginx on a different path/host than the default ws://<host>:3001.
# Example: NEXT_PUBLIC_WS_URL=wss://claude-gui.internal
NEXT_PUBLIC_WS_URL=
